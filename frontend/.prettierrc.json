{
   "tabWidth": 2,
   "printWidth": 100,
   "singleQuote": false,
   "trailingComma": "all",
   "arrowParens": "always",
   "semi": true,
   "bracketSpacing": true,
   "bracketSameLine": false,
   "jsxSingleQuote": false,
   "quoteProps": "as-needed",
   "useTabs": false,
   "proseWrap": "preserve",
   "htmlWhitespaceSensitivity": "css",
   "endOfLine": "lf",
   "embeddedLanguageFormatting": "auto"
}
